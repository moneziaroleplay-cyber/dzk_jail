# ⛓️ DZK Jail - Système de Panel Administration

Système de Jail avancé pour serveurs FiveM (ESX) avec interface NUI, logs Discord complets et immersion sonore.

---

## 📂 Structure du Script
```text
dzk_jail/
├─ fxmanifest.lua   # Configuration
├─ client.lua       # Logique client & Affichage 3D
├─ server.lua       # Logique serveur, Permissions & Webhooks
├─ html/            # Interface NUI
│  ├─ index.html
│  ├─ style.css
│  └─ script.js
└─ sounds/          # Audio (.mp3)
   ├─ prison_alarm.mp3
   └─ prison_voice.mp3
----- CLIENT.LUA ------
local jailCoords = vector3(1644.580200, 2527.608886, 45.556762)
local unjailCoords = vector3(-262.971436, -901.200012, 32.296020)


---client.lua texte sur le joueurs---

function DrawText3D(x, y, z, text)
    local onScreen, _x, _y = World3dToScreen2d(x, y, z)
    local camCoords = GetGameplayCamCoords()
    local distance = #(vector3(x, y, z) - camCoords)
    local scale = (1 / distance) * 2
    if scale > 0.5 then scale = 0.5 end

    if onScreen then
        SetTextScale(0.35 * scale, 0.35 * scale)
        SetTextFont(4)
        SetTextProportional(1)
        SetTextCentre(true)
        SetTextOutline()
        SetTextEntry("STRING")
        AddTextComponentString(text)
        DrawText(_x, _y)
    end
end

-------------------------------sounds-----------------------------------------

SendNUIMessage({ action = "playSound", sound = "prison_alarm" })
SendNUIMessage({ action = "playSound", sound = "prison_voice" })


